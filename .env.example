# --- Supabase Configuration ---
# Your Supabase Project URL (e.g., https://your-project-ref.supabase.co)
SUPABASE_URL=

# Your Supabase Service Role Key (used by backend to write data bypass RLS)
# WARNING: Keep this secret!
SUPABASE_KEY=

# Your Supabase Anon Key (used by frontend client to perform auth)
SUPABASE_ANON_KEY=

# Your Supabase JWT Secret (used by backend to verify access tokens)
# Get this from Project Settings -> API -> JWT Settings -> JWT Secret
SUPABASE_JWT_SECRET=

# (Optional) Redirect URL for Google OAuth (defaults to http://localhost:8501)
# AUTH_REDIRECT_URL=http://localhost:8501

# --- LLM API Configuration ---
# Your Groq API Key (from console.groq.com)
GROQ_API_KEY=

# --- ML Model Configuration (Optional) ---
# Defaults to all-MiniLM-L6-v2
# SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
